#!/usr/bin/env bash
# Shared utilities for worktree management scripts.
# Source this file: source "${BASH_SOURCE[0]%/*}/lib/worktree-utils"

# Branch name -> URL/filesystem slug (lowercase, slashes->hyphens, alphanumeric+hyphens only)
compute_slug() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | tr '/' '-' | tr -cd '[:alnum:]-'
}

# Absolute path to the main (primary) worktree for the current repo
get_main_root() {
    git worktree list | head -1 | awk '{print $1}'
}

# Sibling directory path for a given branch's worktree
get_worktree_path() {
    local branch="$1"
    local main_root slug
    main_root=$(get_main_root)
    slug=$(compute_slug "$branch")
    echo "$(dirname "$main_root")/$(basename "$main_root")-${slug}"
}

# Read a single value from a .env file (last match wins, handles values containing =)
get_env_value() {
    local key="$1" file="$2"
    grep -E "^${key}=" "$file" 2>/dev/null | tail -1 | cut -d= -f2-
}

# Find a free port starting from $1, avoiding ports already claimed by sibling worktrees
find_free_port() {
    local port="$1"
    local main_root sibling_dir repo_name used_ports
    main_root=$(get_main_root)
    sibling_dir=$(dirname "$main_root")
    repo_name=$(basename "$main_root")
    used_ports=$(grep -h -r "^APP_PORT=\|^VITE_PORT=" "${sibling_dir}/${repo_name}-"*/.env 2>/dev/null | cut -d= -f2 | sort -n)
    while echo "$used_ports" | grep -qx "$port"; do
        port=$((port + 1))
    done
    echo "$port"
}

# Rewrite the port in a URL (scheme://host[:port] -> scheme://host:new_port)
_rewrite_url_port() {
    local url="$1" new_port="$2"
    local base
    base=$(printf '%s' "$url" | sed -E 's|(^[^:]+://[^/:]+)(:[0-9]+)?.*|\1|')
    [ -z "$base" ] && { printf 'http://localhost:%s' "$new_port"; return; }
    [ "$new_port" = "80" ] && printf '%s' "$base" || printf '%s:%s' "$base" "$new_port"
}

# Set or append a key=value in a .env file (in-place, preserves line order)
_set_env_key() {
    local key="$1" val="$2" file="$3"
    local tmp
    tmp=$(mktemp)
    awk -v k="$key" -v v="$val" '
        index($0, k"=") == 1 { print k"="v; found=1; next }
        { print }
        END { if (!found) print k"="v }
    ' "$file" > "$tmp" && mv "$tmp" "$file"
}

# Patch worktree-specific values into a .env file
patch_worktree_env() {
    local env_file="$1" repo_name="$2" slug="$3" app_port="$4" vite_port="$5"
    local existing_url app_url
    existing_url=$(get_env_value APP_URL "$env_file")
    if [ -n "$existing_url" ]; then
        app_url=$(_rewrite_url_port "$existing_url" "$app_port")
    elif [ "$app_port" = "80" ]; then
        app_url="http://localhost"
    else
        app_url="http://localhost:${app_port}"
    fi
    _set_env_key COMPOSE_PROJECT_NAME "${repo_name}-${slug}" "$env_file"
    _set_env_key APP_URL "$app_url" "$env_file"
    _set_env_key APP_PORT "$app_port" "$env_file"
    _set_env_key VITE_PORT "$vite_port" "$env_file"
}
